#!/usr/bin/env bash

VERSION=$1

sed -i '' "s/spec.version = \".*\"/spec.version = \"$VERSION\"/" ./binxtils.gemspec
bundle
git add Gemfile.lock binxtils.gemspec
git commit -m "Bump version for $VERSION"
git push
git tag v$VERSION
git push --tags
gem build binxtils.gemspec
gem push "binxtils-$VERSION.gem" --host https://rubygems.org
rm "binxtils-$VERSION.gem"
